<resources>
    <string name="app_name">KidLock TV</string>

    <!-- ================= Prominent-disclosure strings (shown BEFORE opening OS settings) ================= -->
    <string name="accessibility_disclosure">KidLock TV uses the Accessibility service only to read the NAME of the app currently on screen, so it can show your lock screen when someone opens an app you chose to lock. It never reads, collects, or transmits the text or content on your screen. All processing stays on this device, and the app keeps working (set your PIN, choose apps, preview the lock) even if you skip this step.</string>

    <!-- ================= Accessibility service (system-facing) ================= -->
    <string name="accessibility_service_label">KidLock TV</string>
    <string name="accessibility_service_description">Lets KidLock TV notice when an app you chose to lock is opened, so it can show your lock screen. It only uses the foreground app\'s name and never reads or stores your screen content — everything stays on this device.</string>
    <string name="accessibility_service_summary">Detects locked apps on-device so KidLock TV can protect them with your PIN.</string>

